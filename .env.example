# --- Supabase (required) ---
# Project URL and anon (public) key from your Supabase project's API settings.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service-role key — SERVER-ONLY, never exposed to the client. Used solely by the
# cron routes (daily sweep + integrations poll). Keep it secret.
SUPABASE_SERVICE_ROLE_KEY=

# --- Application (required) ---
# The public origin of the deployed app, used to build invitation links and auth
# redirect URLs. MUST be your real site URL in production (e.g. https://app.example.com).
# The code reads NEXT_PUBLIC_SITE_URL and falls back to http://localhost:3000 only
# outside production. A production build/runtime without it fails closed.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Optional Supabase social login (disabled by default) ---
# These are server-side feature flags, not OAuth credentials. Provider client
# ids/secrets belong in Supabase Auth and must never use NEXT_PUBLIC variables.
# Set a flag to 1 only after the provider and redirect allowlist checkpoints in
# docs/deployment.md are complete.
GOOGLE_AUTH_ENABLED=
MICROSOFT_AUTH_ENABLED=

# --- Membership invitation email (optional until go-live) ---
# Both values are SERVER-ONLY. If either is absent, invitations are retained as
# `not_configured` and no network request is made; an operator can retry later.
# Verify the sending subdomain in Resend before enabling this in production.
RESEND_API_KEY=
INVITATION_FROM_EMAIL=ComplianceHub <invites@example.com>

# --- Cron automation (required for scheduled sweeps) ---
# High-entropy secret. Vercel Cron sends `Authorization: Bearer <CRON_SECRET>`;
# both /api/cron/daily and /api/cron/integrations-sync reject any other request.
CRON_SECRET=

# --- GitHub / Jira provider authorization through Nango (optional) ---
# All values are SERVER-ONLY. The browser receives only a short-lived Connect
# session token; NANGO_SECRET_KEY is used only by server actions and Nango Proxy.
# Create the two integration IDs in Nango after registering the corresponding
# GitHub/Jira OAuth apps. Until the required values exist, Settings → Connections
# returns an explicit "provider setup required" state and makes no provider call.
NANGO_BASE_URL=https://api.nango.dev
NANGO_SECRET_KEY=
NANGO_GITHUB_INTEGRATION_ID=
NANGO_JIRA_INTEGRATION_ID=

# --- Continuous evidence automation (optional; leave unset for the safe sandbox) ---
# Unset/absent: evidence sources use the built-in FAKE collector (no live network).
# Set to 1 ONLY once you have registered real Google Workspace / GitHub / AWS OAuth
# apps and stored a valid access token on the source. See docs/deployment.md.
EVIDENCE_LIVE=

# --- Twilio WhatsApp monitoring alerts (optional; complete gate) ---
# Unset any value below: WhatsApp channels are deterministically skipped and no
# Twilio request is made. The recipient is channel-specific in alert_channels
# config as { "to": "+447700900123" }; code normalizes both addresses to the
# required whatsapp: E.164 form. These credentials are SERVER-ONLY.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=

# --- Application encryption key (REQUIRED before live connection credentials) ---
# Base64 of a 32-byte (256-bit) key. Encrypts local developer tokens and Slack
# webhook URLs before they are written to the database (AES-256-GCM). Production
# GitHub/Jira OAuth tokens stay in Nango and are never stored by ComplianceHub.
# Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# Keep this stable — rotating it makes previously-stored secrets undecryptable.
APP_ENCRYPTION_KEY=
